# Docker build context exclusions for the control-plane image build.
#
# Anything listed here is NOT shipped to the docker daemon when
# `docker build` runs against this directory. Cuts the build context
# transfer time and avoids accidentally baking dev artifacts into
# the image.

# Git metadata
.git
.gitignore

# Build outputs (the Go binary is built fresh by the Docker build /
# goreleaser; web/dist is produced INSIDE the docker build by the
# web-build stage — see below).
bin/
control-plane

# JavaScript dev dependencies — these are huge and node_modules is
# re-installed inside the web-build Docker stage via `npm ci`.
web/node_modules/
web/.pnpm-store/
web/.npm/

# Web bundle — produced INSIDE the docker build by the web-build stage
# (npm ci + npm run build), never copied from the host. Keeping host-side
# dist out of the build context prevents the recurring "browser loads
# HTML referencing stale bundle hashes" bug: the embedded HTML and the
# embedded assets in the image are now built from the same source tree
# in the same stage, byte-for-byte consistent. Host devs running
# `npm run build` outside docker get a local dist for `go build` outside
# docker — irrelevant to docker images.
web/dist/

# IDE / editor noise
.vscode/
.idea/
*.swp
.DS_Store

# Local env files (never bake credentials into images)
.env
.env.local
deploy/compose/.env
deploy/compose/.env.smoke

# Test fixtures we don't need at runtime
testdata/

# Documentation source — the binary doesn't need it
docs/

# CI / GitHub config
.github/

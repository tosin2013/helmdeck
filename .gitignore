
# Auto-generated MCP server context (added automatically)
.mcp-server-context.md

# Root-level npm artifacts (root package.json carries only the vercel CLI;
# website/ has its own workspace).
/node_modules/

# Local PRD (input to ADR generation; not tracked)
PRD.md

# Claude Code workspace
.claude/

# Compose env files contain generated secrets (HELMDECK_JWT_SECRET,
# HELMDECK_VAULT_KEY, HELMDECK_KEYSTORE_KEY, HELMDECK_ADMIN_PASSWORD).
# scripts/install.sh writes deploy/compose/.env.local with chmod 600;
# never commit any of these. .env.example stays tracked as the
# documented template.
deploy/compose/.env
deploy/compose/.env.local
deploy/compose/.env.*
!deploy/compose/.env.example

# Build artifacts
/bin/
*.test
*.out
coverage.txt
# `dist/` ignores the goreleaser output directory at the repo root
# AND any nested `dist/` directories. The web UI build (web/dist)
# also lands here — we keep the placeholder index.html in version
# control so the Go //go:embed directive compiles before
# `make web-build` has ever run, and let the per-directory
# web/.gitignore re-include it explicitly. The `!web/dist/index.html`
# rule below makes that exception unambiguous regardless of how
# git's ignore precedence orders the per-directory file.
dist/
!web/dist/
!web/dist/index.html


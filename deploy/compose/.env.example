# helmdeck — Compose stack environment variables
#
# Copy this file to .env.local (which is gitignored) and fill in
# real values, OR run scripts/install.sh which generates a fresh
# .env.local with strong random values for every secret.
#
#   cp deploy/compose/.env.example deploy/compose/.env.local
#   # …edit .env.local…
#   docker compose -f deploy/compose/compose.yaml --env-file deploy/compose/.env.local up -d
#
# Treat every value below as a secret. Never check .env.local into
# version control.

# ── Required ────────────────────────────────────────────────────────────

# JWT signing secret. The control plane signs every minted token
# with this. 32 raw bytes hex-encoded — generate via:
#   openssl rand -hex 32
HELMDECK_JWT_SECRET=changeme-32-byte-hex-string

# Credential vault encryption key (T501, ADR 007). Intentionally
# distinct from HELMDECK_KEYSTORE_KEY so a leak of one domain does
# not compromise the other. 32 raw bytes hex-encoded.
HELMDECK_VAULT_KEY=changeme-32-byte-hex-string

# AI provider keystore encryption key (T203). Used to encrypt the
# Anthropic / OpenAI / Gemini / Ollama / Deepseek API keys. 32-byte hex.
HELMDECK_KEYSTORE_KEY=changeme-32-byte-hex-string

# Management UI admin password. The login form at http://localhost:3000
# accepts (HELMDECK_ADMIN_USERNAME, HELMDECK_ADMIN_PASSWORD) and mints
# a 12-hour JWT. If unset, the UI login endpoint returns 503 — operators
# can still mint tokens via the CLI:
#   ./bin/control-plane -mint-token=alice -mint-token-scopes=admin
HELMDECK_ADMIN_PASSWORD=changeme

# ── Optional ────────────────────────────────────────────────────────────

# Override the default username (admin).
HELMDECK_ADMIN_USERNAME=admin

# Host docker group id. The control plane runs as a non-root user
# inside its container, so it needs the host's docker group GID
# (usually 999 on Debian/Ubuntu) to read /var/run/docker.sock. The
# install script auto-detects this; override here only if you've
# remapped the docker group.
HELMDECK_DOCKER_GID=999

# Egress allowlist (T508). Comma-separated CIDRs of internal hosts
# that pack handlers should be allowed to reach despite the default
# block on RFC 1918 / metadata IP / loopback. Leave empty for the
# strict default (recommended unless you have an internal CI server
# or self-hosted git that pack handlers need).
HELMDECK_EGRESS_ALLOWLIST=

# Sandbox tuning (T509). Override only if you're running pack
# handlers that legitimately fork heavily (parallel test runners,
# build systems doing make -j32, etc.).
HELMDECK_PIDS_LIMIT=1024
# HELMDECK_SECCOMP_PROFILE=/etc/helmdeck/chrome-strict.json

# Per-pack image overrides for the language sidecars. Operators
# who fork the sidecar images per docs/SIDECAR-LANGUAGES.md point
# their forks here.
# HELMDECK_SIDECAR_PYTHON=ghcr.io/yourorg/helmdeck-sidecar-python:latest
# HELMDECK_SIDECAR_NODE=ghcr.io/yourorg/helmdeck-sidecar-node:latest

# Sidecar browser image override. The control plane spawns one of
# these per session-needing pack call. The local `make sidecar-build`
# target produces `helmdeck-sidecar:dev`; if you ship a published
# image to ghcr.io, point this at it. Defaults to
# `ghcr.io/tosin2013/helmdeck-sidecar:latest` when unset.
HELMDECK_SIDECAR_IMAGE=helmdeck-sidecar:dev

# AI provider env-var fast paths (T202a). The keystore at
# /api/v1/providers/keys is the canonical place to store provider
# credentials, but two escape hatches exist for cases where editing
# the keystore over HTTP is inconvenient or for OpenAI-compatible
# aggregators that the keystore schema does not yet model:
#
#   1. HELMDECK_<PROVIDER>_MODELS — comma-separated model catalog
#      override for a provider that DOES live in the keystore.
#      Example: HELMDECK_OPENAI_MODELS=gpt-4o,gpt-4o-mini
#
#   2. HELMDECK_OPENROUTER_API_KEY — registers OpenRouter as an
#      OpenAI-compatible provider with Name="openrouter" and
#      BaseURL="https://openrouter.ai/api". Models passed in the
#      request body verbatim because helmdeck splits provider/model
#      on the FIRST `/` only — so a request for
#      `openrouter/minimax/minimax-m2.7` parses correctly. Override
#      the model catalog with HELMDECK_OPENROUTER_MODELS or the base
#      URL with HELMDECK_OPENROUTER_BASE_URL.
# HELMDECK_OPENROUTER_API_KEY=sk-or-v1-…
# HELMDECK_OPENROUTER_MODELS=minimax/minimax-m2.7,anthropic/claude-3.5-sonnet

# Firecrawl integration (T807b, ADR 035). When set to "true", the
# built-in `web.scrape` pack calls the self-hosted Firecrawl stack
# instead of returning a "disabled" error. Bring up the stack with
# the overlay:
#   docker compose -f deploy/compose/compose.yaml \
#                  -f deploy/compose/compose.firecrawl.yml \
#                  --env-file deploy/compose/.env.local up -d
# HELMDECK_FIRECRAWL_URL defaults to http://helmdeck-firecrawl:3002
# (the service name in the overlay). Override if running Firecrawl
# on a different host or port.
# HELMDECK_FIRECRAWL_ENABLED=true
# HELMDECK_FIRECRAWL_URL=http://helmdeck-firecrawl:3002

# Playwright MCP (T807a, ADR 035). The browser sidecar bundles
# `@playwright/mcp` and, on session start, attaches it to the same
# Chromium process the existing chromedp packs use — via CDP on
# 127.0.0.1:9222. The MCP accessibility-tree surface is exposed on
# the container at 0.0.0.0:8931 and surfaced to API clients as
# `playwright_mcp_endpoint` on every session response.
#
# Defaults to "true" inside the sidecar image, so there is nothing
# to configure for the happy path. Set to "false" on tiny VMs where
# the extra ~80 MB of Node + Playwright runtime isn't worth it;
# packs that would drive Playwright MCP (e.g. `web.test`, T807e)
# will then return a clear disabled error instead of silently
# spawning a process.
# HELMDECK_PLAYWRIGHT_MCP_ENABLED=true

# Docling integration (T807c, ADR 035). When set to "true", the
# built-in `doc.parse` pack calls the self-hosted Docling service
# for layout-aware PDF / DOCX / PPTX / HTML / image parsing instead
# of returning a "disabled" error. `doc.ocr` (Tesseract) stays
# available regardless — Docling is the heavier-weight option.
# Bring up the stack with the overlay:
#   docker compose -f deploy/compose/compose.yaml \
#                  -f deploy/compose/compose.docling.yml \
#                  --env-file deploy/compose/.env.local up -d
# HELMDECK_DOCLING_URL defaults to http://helmdeck-docling:5001.
# HELMDECK_DOCLING_ENABLED=true
# HELMDECK_DOCLING_URL=http://helmdeck-docling:5001

# OpenTelemetry tracing (T510). When set, the control plane exports
# spans for every LLM dispatch, pack execution, and MCP tool call.
# Compatible with any OTLP HTTP backend (Tempo, Jaeger, Honeycomb,
# Datadog, Langfuse).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
# OTEL_SERVICE_NAME=helmdeck-prod
# HELMDECK_OTEL_ENABLED=true

# Dependencies
node_modules/
.pnpm-store/
.npm/

# Build output — except the placeholder index.html that lets the
# Go control plane compile before `make web-build` has ever run.
# `make web-build` overwrites the placeholder with the real bundle.
dist/*
!dist/index.html
!dist/.gitkeep

# TypeScript incremental build cache and the .d.ts/.js shadows
# tsc emits next to vite.config.ts when running `tsc -b`. None of
# these should be checked in — `make web-build` regenerates them.
*.tsbuildinfo
vite.config.d.ts
vite.config.js

# IDE / editor
.vscode/
.idea/
*.swp

# Local env overrides
.env.local
.env.development.local
